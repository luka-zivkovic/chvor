# Chvor Configuration
# Copy this file to .env and fill in the values you need.
# Only LLM provider keys are required — everything else is optional.

# ---- LLM Providers (at least one required) ----
# Chvor supports multiple providers. Set at least one.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AI...

# ---- CORS (optional) ----
# Comma-separated list of allowed origins for CORS.
# If unset, defaults to http://localhost:5173.
# ALLOWED_ORIGINS=https://your-domain.com

# ---- Auth (legacy — see note below) ----
# CHVOR_TOKEN is now deprecated in favor of the built-in auth system.
# If set, it will be auto-imported as an API key on first run.
# New installs should use the Settings > Security UI to configure auth.
# CHVOR_TOKEN=

# ---- Channels (optional) ----
# Connect your AI to external chat platforms.
# These can also be configured through the Settings UI.
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ---- LLM Override (optional) ----
# Force a specific provider/model instead of using the UI config.
# CHVOR_PROVIDER=anthropic
# CHVOR_MODEL=claude-sonnet-4-20250514

# ---- Browser (optional) ----
# Controls the headless browser for web-agent tool.
# CHVOR_BROWSER_HEADLESS=true
