{
  "$schema": "https://raw.githubusercontent.com/nicedeveloper/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Chvor",
  "version": "0.1.0",
  "identifier": "com.chvor.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Chvor",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 550,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://api.github.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {}
}
